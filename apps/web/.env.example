# Copy to .env.local and fill in values — never commit .env.local!

# Alchemy
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_key_here

# OnchainKit (get from https://portal.cdp.coinbase.com — free)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_key_here

# Paymaster URL (from Coinbase CDP portal — enables sponsored gas)
# See: https://docs.base.org/base-account/improve-ux/sponsor-gas/paymasters
NEXT_PUBLIC_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/YOUR_KEY

# Builder Code (from https://base.org/builders/builder-codes)
# This earns you a share of gas fees Base collects from your users
NEXT_PUBLIC_BUILDER_CODE=your_builder_code_here

# Neynar API Key for Farcaster profiles
NEYNAR_API_KEY=your_neynar_api_key_here

# WalletConnect Project ID (from cloud.walletconnect.com — free)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Deployed contract addresses (fill in after running forge script/Deploy.s.sol)
NEXT_PUBLIC_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BURN_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FEE_COLLECTOR_ADDRESS=0x0000000000000000000000000000000000000000

# Set to 'testnet' for development, 'mainnet' for production
NEXT_PUBLIC_NETWORK=testnet
