# Copy to .env and fill in values — never commit .env!

PORT=3001
NODE_ENV=development

# Alchemy (get from alchemy.com — free tier works)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Supabase (from supabase.com > Settings > API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Upstash Redis (from upstash.com)
REDIS_URL=https://YOUR_DB.upstash.io
REDIS_TOKEN=your_upstash_token_here

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# DustSweepRouter contract address (deployed on Base)
DUST_SWEEP_ROUTER_ADDRESS=your_deployed_contract_address_here
